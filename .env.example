# Copy this file to .env and fill in your values for local testing.
# The .env file is gitignored — never commit real tokens.

# -------------------------------------------------------------------
# Required
# -------------------------------------------------------------------

# GitHub Personal Access Token (needs `repo` scope)
# Generate one at: https://github.com/settings/tokens
gh_token=your_github_personal_access_token_here

# Your MyAnimeList username
mal_username=your_mal_username

# Target repository in owner/repo format
repo_path=yourgithubname/yourrepo

# -------------------------------------------------------------------
# Optional
# -------------------------------------------------------------------

# Branch to push the updated README to (default: main)
repo_branch=main

# Markdown file to update (default: README.md)
repo_filename=README.md

# Maximum entries shown per list section — 0 means unlimited (default: 0)
max_entries=5

# Set to true to also update <!-- MAL_MANGA...: --> sections (default: false)
enable_manga=false

# Set to true to show your MAL score next to each title (default: false)
show_score=false
